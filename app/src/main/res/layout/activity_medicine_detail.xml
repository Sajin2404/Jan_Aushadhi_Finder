<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"

    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <include layout="@layout/header_layout"/>

        <!-- BRAND NAME -->
        <TextView
            android:id="@+id/brandName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Medicine Name"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginTop="20dp"/>

        <!-- GENERIC NAME -->
        <TextView
            android:id="@+id/genericName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Generic Name"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginTop="8dp"/>

        <!-- CATEGORY -->
        <TextView
            android:id="@+id/category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:layout_marginTop="8dp"/>

        <!-- PRICE CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="18dp"
            android:elevation="4dp"
            android:layout_marginTop="24dp">

            <!-- TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Price Comparison"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"/>

            <!-- BRAND PRICE -->
            <TextView
                android:id="@+id/brandPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Brand Price"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#D32F2F"
                android:layout_marginTop="12dp"/>

            <!-- GENERIC PRICE -->
            <TextView
                android:id="@+id/genericPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Generic Price"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:layout_marginTop="8dp"/>

            <!-- SAVINGS -->
            <TextView
                android:id="@+id/savings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Savings"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginTop="10dp"/>

        </LinearLayout>

        <!-- ABOUT -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="About this Medicine"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginTop="28dp"/>

        <!-- DESCRIPTION -->
        <TextView
            android:id="@+id/medicineDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Medicine description"
            android:textSize="15sp"
            android:textColor="#444444"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="10dp"/>

        <!-- INFO CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginTop="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medicine Information"
                android:textStyle="bold"
                android:textSize="17sp"
                android:textColor="#000000"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✔ Government approved generic medicine"
                android:textSize="14sp"
                android:textColor="#333333"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✔ Affordable alternative to branded medicines"
                android:textSize="14sp"
                android:textColor="#333333"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✔ Available at Jan Aushadhi Kendras"
                android:textSize="14sp"
                android:textColor="#333333"
                android:layout_marginTop="6dp"/>

        </LinearLayout>

        <!-- CHECK AVAILABILITY BUTTON -->
        <Button
            android:id="@+id/checkAvailabilityBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Check Nearby Availability"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2E7D32"
            android:layout_marginTop="30dp"/>

        <!-- NAVIGATION BUTTON -->
        <Button
            android:id="@+id/navigationBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Navigate to Nearby Store"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1565C0"
            android:layout_marginTop="12dp"/>

    </LinearLayout>

</ScrollView>